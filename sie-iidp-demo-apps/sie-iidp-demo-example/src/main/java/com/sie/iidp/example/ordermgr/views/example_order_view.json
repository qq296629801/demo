{
  "views": {
    "demo_example_order_grid_search": {
      "mode": "primary",
      "name": "Example-订单-搜索",
      "model": "example_order",
      "type": "search",
      "body": {
        "columns": [
          "orderSerial",
          "orderCode",
          "orderName"
        ],
        "type": "search"
      }
    },
    "demo_example_order_grid": {
      "body": {
        "checkbox": "multiple_2",
        "buttons": [
          {
            "action": "preview",
            "auth": "read",
            "name": "详情"
          },
          {
            "action": "edit",
            "auth": "update",
            "name": "编辑"
          },
          {
            "action": "fasong",
            "auth": "fasong",
            "name": "发送",
            "view": {
              "click": {
                "openView": {
                  "showType": "dialog",
                  "title": "",
                  "width": "",
                  "preId": "iidp_message_send_policy_fmk_001_",
                  "model": "iidp_message_send_policy",
                  "type": "iidp_message_send_policy_grid,iidp_message_send_policy_search",
                  "api": {
                    "grid": {
                      "save": {
                        "params": {
                          "args": {
                          },
                          "model": "iidp_message_send_policy_trigger",
                          "tag": "master",
                          "service": "notice",
                          "app": "sie-iidp-message-push"
                        },
                        "reqPrep": " (t, params) => {\n let mainTable = tech_app.page.getNode('demo_example_order_menu_table_main_table');\n params.args.values = mainTable.$ds.mainTableRowData;\n params.args.ruleid = t.$ds.mainTableRowData.id;\n params.args.receiveUserIds = [tech.userInfo.id];\n return params;\n }",
                        "reqAfter": "(vm, res) => { return res; }"
                    }
                  }
                }
              }
            }
          }
        }
        ],
        "headerSortRemote": true,
        "sortMultiple": true,
        "columns": [
          "id",
          "orderName",
          "orderSerial",
          "orderCode",
          "isEnable"
        ],
        "tbar": [
          {
            "name": "添加",
            "action": "add",
            "auth": "add",
            "view": {
              "click": {
                "title": "新增订单",
                "openView": {
                  "width": "30%",
                  "height": "30vh",
                  "top": "30vh",
                  "model": "example_order",
                  "app": "sie-iidp-demo-example",
                  "preId": "encoder_rule_detail_00_",
                  "showType": "dialog",
                  "type": "demo_example_order_grid_param_form",
                  "api": {
                    "form": {
                      "save": {
                        "params": {
                          "app": "common-encoder",
                          "model": "example_order",
                          "service": "createOrder",
                          "args": {
                            "orderName": "$form.curForm.orderName"
                          }
                        },
                        "reqAfter": "(vm,res)=>{ \n const refresh = tech_app.page.getNode('demo_example_order_menu_table_main_toolbar_refresh');\n refresh.instance.click();\n return res\n }"
                      }
                    }
                  }
                }
              }
            }
          },
          {
            "action": "delete",
            "auth": "delete",
            "name": "删除"
          },
          {
            "name": "启用",
            "action": "enable",
            "auth": "enable",
            "model": "example_order",
            "service": "enableDisable",
            "actionAfter": "refreshTable",
            "options": {
              "icon": "el-icon-open"
            },
            "args": {
              "bind_ids": "$ds.checkedDataIds",
              "statusFlag": "1"
            },
            "bind_disabled": "${$ds.checkedDataList.length === 0}"
          },
          {
            "name": "禁用",
            "action": "disable",
            "auth": "disable",
            "model": "example_order",
            "service": "enableDisable",
            "actionAfter": "refreshTable",
            "options": {
              "icon": "el-icon-turn-off"
            },
            "args": {
              "bind_ids": "$ds.checkedDataIds",
              "statusFlag": "0"
            },
            "bind_disabled": "${$ds.checkedDataList.length === 0}"
          }
        ],
        "type": "grid"
      },
      "mode": "primary",
      "model": "example_order",
      "name": "Example-订单-列表",
      "type": "grid"
    },
    "demo_example_order_grid_param_form": {
      "mode": "primary",
      "name": "Example-订单-表单",
      "model": "example_order",
      "type": "form",
      "body": {
        "buttons": [
          "@defaults"
        ],
        "columns": [
          "orderName"
        ],
        "tbar": [
          "@defaults"
        ],
        "type": "form"
      }
    }
  }
}