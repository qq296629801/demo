{
  "views": {
    "demo_example_class_grid_search": {
      "mode": "primary",
      "name": "Example-班级-搜索",
      "model": "example_class",
      "type": "search",
      "body": {
        "columns": [
          "className"
        ],
        "type": "search"
      }
    },
    "demo_example_class_grid": {
      "body": {
        "checkbox": "multiple_2",
        "typeView": "subTable",
        "buttons": [
          {
            "action": "preview",
            "auth": "read",
            "name": "详情"
          },
          {
            "action": "edit",
            "auth": "update",
            "name": "编辑"
          }
        ],
        "headerSortRemote": true,
        "sortMultiple": true,
        "gridEditMode": {
          "mode": "multipleRow",
          "rowBtns": ["update","add","delete"],
          "defaultCancelEdit": true
        },
        "columns": [
          {
            "displayName": "班级编码",
            "name": "classCode",
            "sortable": true,
            "rowEditable": true
          },
          {
            "displayName": "班级名称",
            "name": "className",
            "sortable": true,
            "rowEditable": true
          },
          "create_user",
          "create_date",
          "update_user",
          "update_date"
        ],
        "tbar": [
          {
            "action": "create",
            "auth": "create",
            "name": "新增"
          },
          {
            "action": "delete",
            "auth": "delete",
            "name": "删除"
          }
        ],
        "type": "grid"
      },
      "mode": "primary",
      "model": "example_class",
      "name": "Example-班级-列表",
      "type": "grid"
    },
    "demo_example_class_grid_param_form": {
      "mode": "primary",
      "name": "Example-班级-表单",
      "model": "example_class",
      "type": "form",
      "body": {
        "buttons": [
          "@defaults"
        ],
        "columns": [
          "classCode",
          "className"
        ],
        "tbar": [
          "@defaults"
        ],
        "type": "form",
        "tabs": [
          {
            "header": "学生",
            "isAloneSave": true,
            "tbar": [
              {
                "name": "添加",
                "action": "addEr",
                "auth": "update"
              },
              {
                "name": "删除",
                "action": "deleteEr",
                "auth": "deleteEr"
              }
            ],
            "body": {
              "model": "example_student",
              "type": "demo_example_student_grid,demo_example_student_grid_search",
              "field": "studentList",
              "buttons": [
                {
                  "action": "preview",
                  "auth": "read",
                  "name": "详情"
                },
                {
                  "name": "编辑",
                  "action": "updateEr",
                  "auth": "update",
                  "enableCondition": "(row) => {return row[0].isEnable !== true;}"
                }
              ],
              "pagin": {
                "limit": 0,
                "display": false,
                "unPaging": true
              },
              "columns": [
                "name"
              ]
            }
          }
        ]
      }
    }
  }
}