{
  "views": {
    "demo_example_unit_fmk_grid_search": {
      "mode": "primary",
      "name": "Example-单位框架-搜索",
      "model": "example_unit_fmk",
      "type": "search",
      "body": {
        "columns": [
          "unitName",
          "effectDay"
        ],
        "type": "search"
      }
    },
    "demo_example_unit_fmk_grid": {
      "body": {
        "checkbox": "multiple_2",
        "buttons": [
          {
            "action": "preview",
            "auth": "read",
            "name": "详情"
          },
          {
            "action": "edit",
            "auth": "update",
            "name": "编辑"
          }
        ],
        "headerSortRemote": true,
        "sortMultiple": true,
        "columns": [
          "unitCode",
          "unitName",
          "unitType",
          "effectDay",
          "isEnable",
          "create_user",
          "create_date",
          "update_user",
          "update_date",
          "provinceCode",
          "cityCode"
        ],
        "tbar": [
          {
            "action": "create",
            "auth": "create",
            "name": "新增"
          },
          {
            "action": "delete",
            "auth": "delete",
            "name": "删除"
          },
          {
            "name": "导出1",
            "action": "export",
            "source": "selected",
            "model": "example_unit_fmk",
            "service": "excelExport"
          },
          {
            "name": "启用",
            "action": "enable",
            "auth": "enable",
            "model": "example_unit_fmk",
            "service": "enableDisable",
            "actionAfter": "refreshTable",
            "options": {
              "icon": "el-icon-open"
            },
            "args": {
              "bind_ids": "$ds.checkedDataIds",
              "statusFlag": "1"
            },
            "bind_disabled": "${$ds.checkedDataList.length === 0}"
          },
          {
            "name": "禁用",
            "action": "disable",
            "auth": "disable",
            "model": "example_unit_fmk",
            "service": "enableDisable",
            "actionAfter": "refreshTable",
            "options": {
              "icon": "el-icon-turn-off"
            },
            "args": {
              "bind_ids": "$ds.checkedDataIds",
              "statusFlag": "0"
            },
            "bind_disabled": "${$ds.checkedDataList.length === 0}"
          },
          {
            "name": "导入",
            "statement": "_fullImport",
            "modelName": "example_unit_fmk",
            "templateName": "下载模板-单位框架",
            "fileName": "@filePath(unit_import_template)",
            "buttonList": [
              {
                "text": "下载模板",
                "action": "downloadTemplate",
                "icon": "el-icon-document"
              },
              {
                "text": "准确性校验",
                "action": "importValidate"
              },
              {
                "text": "强制导入",
                "action": "forceImport"
              },
              {
                "text": "确认导入",
                "action": "confirmImport"
              }
            ]
          },
          {
            "name": "导出",
            "statement": "_fullExport",
            "modelName":"example_unit_fmk"
          }
        ],
        "type": "grid"
      },
      "mode": "primary",
      "model": "example_unit_fmk",
      "name": "Example-单位框架-列表",
      "type": "grid"
    },
    "demo_example_unit_fmk_grid_param_form": {
      "mode": "primary",
      "name": "Example-单位框架-表单",
      "model": "example_unit_fmk",
      "type": "form",
      "body": {
        "buttons": [
          "@defaults"
        ],
        "columns": [
          "unitCode",
          {
            "displayName": "名称",
            "name": "unitName",
            "custom": true,
            "type": "input"
          },
          "unitType",
          {
            "displayName": "生效日期",
            "name": "effectDay",
            "custom": true,
            "type": "datepicker",
            "defaultValueFn": "return new Date()"
          },
          {
            "type": "select",
            "displayName": "省",
            "name": "provinceCode",
            "custom": true,
            "bind_options": "$ds.provinceData",
            "ds_config": {
              "type": "meta",
              "name": "provinceData",
              "autoRequest": true,
              "options": {
                "params": {
                  "args": {
                    "filter": [],
                    "properties": [
                      "areaCode",
                      "areaName"
                    ],
                    "limit": 0,
                    "offset": 0,
                    "order": "areaCode"
                  },
                  "service": "selectArea",
                  "model": "example_area"
                }
              },
              "bind_on_changeHandler" : "(data) => { console.log(data); console.log(data.self.page.getNode(\"demo_example_unit_fmk_menu_form_main_detail_top_common_items_0_items_cityCode\").data.ds_config.options.params.args);}",
              "reqAfter": "(vm, res) => {console.log(res);let newRes = res.data.map(item => {return {text: item.areaName,value: item.areaCode}}); return newRes;}"
            }
          },
          {
            "type": "select",
            "displayName": "市",
            "name": "cityCode",
            "custom": true,
            "bind_options": "$ds.cityData",
            "ds_config": {
              "type": "meta",
              "name": "cityData",
              "doWhenChange": "reload",
              "options": {
                "params": {
                  "args": {
                    "bind_filter": "$ds.form.provinceCode",
                    "properties": [
                      "areaCode",
                      "areaName"
                    ],
                    "limit": 0,
                    "offset": 0,
                    "order": "areaCode"
                  },
                  "service": "selectCity",
                  "model": "example_area"
                }
              },
              "reqAfter": "(vm, res) => {let newRes = res.data.map(item => {return {text: item.areaName,value: item.areaCode}}); return newRes;}"
            }
          }
        ],
        "tbar": [
          "@defaults"
        ],
        "type": "form"
      }
    }
  }
}