{
  "views": {
    "demo_example_text_grid": {
      "body": {
        "checkbox": "multiple_2",
        "buttons": [
          {
            "action": "preview",
            "auth": "read",
            "name": "详情"
          },
          {
            "action": "edit",
            "auth": "update",
            "name": "编辑"
          }
        ],
        "columns": [
          "text1",
          "displayValue",
          "text2",
          "password",
          "mustPassword",
          "bigText",
          "mustBigText",
          "create_user",
          "create_date",
          "update_user",
          "update_date"
        ],
        "tbar": [
          {
            "action": "create",
            "auth": "create",
            "name": "新增"
          },
          {
            "action": "delete",
            "auth": "delete",
            "name": "删除"
          },
          {
            "name": "导出",
            "action": "export",
            "source": "selected",
            "model": "example_text",
            "service": "excelExport"
          }
        ],
        "type": "grid"
      },
      "mode": "primary",
      "model": "example_text",
      "name": "Example文本编辑器-列表",
      "type": "grid"
    },
    "demo_example_text_grid_search": {
      "mode": "primary",
      "name": "Example文本编辑器-搜索",
      "model": "example_text",
      "type": "search",
      "body": {
        "columns": [
          "text1",
          "text2",
          "password",
          "mustPassword",
          "bigText",
          "mustBigText"
        ],
        "type": "search"
      }
    },
    "demo_example_text_grid_param_form": {
      "mode": "primary",
      "name": "Example文本编辑器-表单",
      "model": "example_text",
      "type": "form",
      "body": {
        "buttons": [
          "@defaults"
        ],
        "columns": [
          {
            "label": "只读",
            "text": "只读",
            "type": "checkbox",
            "name": "readOnly",
            "custom": true,
            "mergeList": [
              {
                "name": "visible"
              }
            ]
          },
          {
            "label": "可见",
            "type": "checkbox",
            "text": "可见",
            "name": "visible",
            "custom": true
          },
          {
            "displayName": "文本",
            "name": "text1",
            "bind_on_changeHandler": "(params) => {console.log(params);if(!!params && !!params.__row){params.self.$ds.form.unitCode=params.__row.text1;}else{params.self.$ds.form.text1=''}}",
            "groupConf": {
              "name": "文本编辑器",
              "id": "baseInfo1"
            }
          },
          {
            "displayName": "必填文本",
            "name": "text2",
            "groupConf": {
              "name": "文本编辑器",
              "id": "baseInfo1"
            }
          },
          {
            "displayName": "文本只读",
            "name": "text1ReadOnly",
            "disabled": true,
            "groupConf": {
              "name": "文本编辑器",
              "id": "baseInfo1"
            }
          },
          {
            "displayName": "文本Linq只读",
            "name": "textLinqReadOnly",
            "groupConf": {
              "name": "文本编辑器",
              "id": "baseInfo1"
            },
            "bind_disabled": "${$ds.form.readOnly === true}"
          },
          {
            "displayName": "文本Linq可见",
            "name": "textLinqSee",
            "groupConf": {
              "name": "文本编辑器",
              "id": "baseInfo1"
            },
            "bind_display": "${$ds.form.visible === true}"
          },
          {
            "text": "密码",
            "name": "password",
            "groupConf": {
              "name": "密码编辑器",
              "id": "baseInfo2"
            }
          },
          {
            "text": "必填密码",
            "name": "mustPassword",
            "groupConf": {
              "name": "密码编辑器",
              "id": "baseInfo2"
            }
          },
          {
            "text": "密码只读",
            "name": "passwordReadOnly",
            "disabled": true,
            "groupConf": {
              "name": "密码编辑器",
              "id": "baseInfo2"
            }
          },
          {
            "text": "密码Linq只读",
            "name": "passwordLinqReadOnly",
            "groupConf": {
              "name": "密码编辑器",
              "id": "baseInfo2"
            },
            "bind_disabled": "${$ds.form.readOnly === true}"
          },
          {
            "text": "密码Linq可见",
            "name": "passwordLinqSee",
            "groupConf": {
              "name": "密码编辑器",
              "id": "baseInfo2"
            },
            "bind_display": "${$ds.form.visible === true}"
          },
          {
            "displayName": "大文本",
            "name": "bigText",
            "custom": true,
            "type": "textarea",
            "maxlength": 500,
            "groupConf": {
              "name": "大文本编辑器",
              "id": "baseInfo3"
            }
          },
          {
            "displayName": "必填大文本",
            "name": "mustBigText",
            "custom": true,
            "type": "textarea",
            "groupConf": {
              "name": "大文本编辑器",
              "id": "baseInfo3"
            }
          },
          {
            "displayName": "大文本只读",
            "name": "bigTextReadOnly",
            "custom": true,
            "type": "textarea",
            "disabled": true,
            "groupConf": {
              "name": "大文本编辑器",
              "id": "baseInfo3"
            }
          },
          {
            "displayName": "大文本Linq只读",
            "name": "bigTextLinqReadOnly",
            "custom": true,
            "type": "textarea",
            "groupConf": {
              "name": "大文本编辑器",
              "id": "baseInfo3"
            },
            "bind_disabled": "${$ds.form.readOnly === true}"
          },
          {
            "displayName": "大文本Linq可见",
            "name": "bigTextLinqSee",
            "custom": true,
            "type": "textarea",
            "groupConf": {
              "name": "大文本编辑器",
              "id": "baseInfo3"
            },
            "bind_display": "${$ds.form.visible === true}"
          }
        ],
        "tbar": [
          "@defaults"
        ],
        "type": "form"
      }
    }
  }
}