{
  "storyId": "US-002",
  "description": "新增用户（用户名、昵称、所属部门）",
  "endpoint": "http://localhost:8060",
  "cases": [
    {
      "name": "TC-002-1 正常新增用户",
      "request": {
        "id": "guid-002-1",
        "jsonrpc": "2.0",
        "method": "service",
        "params": {
          "model": "sys_user",
          "service": "create",
          "tag": "master",
          "app": "sie-iidp-demo-sysuser",
          "context": { "uid": "", "lang": "zh_CN" },
          "args": {
            "valuesList": [{ "username": "testuser001", "nickname": "测试用户", "status": "ENABLE", "deptId": "test-dept-id" }]
          }
        }
      },
      "expectedHttpStatus": 200,
      "expectedResult": true
    },
    {
      "name": "TC-002-2 异常 - username 为空",
      "request": {
        "id": "guid-002-2",
        "jsonrpc": "2.0",
        "method": "service",
        "params": {
          "model": "sys_user",
          "service": "create",
          "tag": "master",
          "app": "sie-iidp-demo-sysuser",
          "context": { "uid": "", "lang": "zh_CN" },
          "args": {
            "valuesList": [{ "nickname": "无用户名", "status": "ENABLE" }]
          }
        }
      },
      "expectedHttpStatus": 200,
      "expectedError": true
    }
  ]
}
