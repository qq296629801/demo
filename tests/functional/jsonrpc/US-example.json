{
  "storyId": "US-EXAMPLE",
  "description": "示例用户故事 - 展示 JSON-RPC 测试文件格式。实际使用时请根据 requirements.md 中的 AC 替换本文件内容，文件名改为对应的用户故事编号（如 US-001.json）。",
  "endpoint": "http://localhost:8060",
  "cases": [
    {
      "name": "TC-001 search 正常查询",
      "request": {
        "id": "guid-001",
        "jsonrpc": "2.0",
        "method": "service",
        "params": {
          "model": "example_student",
          "service": "search",
          "tag": "master",
          "app": "sie-iidp-demo-example",
          "context": { "uid": "", "lang": "zh_CN" },
          "args": {
            "filter": [],
            "properties": ["id", "name"],
            "limit": 10,
            "offset": 0,
            "order": "id desc"
          }
        }
      },
      "expectedHttpStatus": 200,
      "expectedResult": true
    },
    {
      "name": "TC-002 search 带 filter 条件查询",
      "request": {
        "id": "guid-002",
        "jsonrpc": "2.0",
        "method": "service",
        "params": {
          "model": "example_student",
          "service": "search",
          "tag": "master",
          "app": "sie-iidp-demo-example",
          "context": { "uid": "", "lang": "zh_CN" },
          "args": {
            "filter": [["name", "like", "%测试%"]],
            "properties": ["id", "name"],
            "limit": 10,
            "offset": 0,
            "order": "id desc"
          }
        }
      },
      "expectedHttpStatus": 200,
      "expectedResult": true
    },
    {
      "name": "TC-003 create 新增记录",
      "request": {
        "id": "guid-003",
        "jsonrpc": "2.0",
        "method": "service",
        "params": {
          "model": "example_student",
          "service": "create",
          "tag": "master",
          "app": "sie-iidp-demo-example",
          "context": { "uid": "", "lang": "zh_CN" },
          "args": {
            "valuesList": [
              { "name": "冒烟测试学生", "studentNo": "ST-SMOKE-001" }
            ]
          }
        }
      },
      "expectedHttpStatus": 200,
      "expectedResult": true
    },
    {
      "name": "TC-004 异常 - 调用不存在的服务",
      "request": {
        "id": "guid-004",
        "jsonrpc": "2.0",
        "method": "service",
        "params": {
          "model": "example_student",
          "service": "nonExistentService",
          "tag": "master",
          "app": "sie-iidp-demo-example",
          "context": { "uid": "", "lang": "zh_CN" },
          "args": {}
        }
      },
      "expectedHttpStatus": 200,
      "expectedError": true
    }
  ]
}
